GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
AUTH_GATEWAY_ISSUER=http://localhost:8080
SESSION_COOKIE_SECURE=false

DATABASE_URL=jdbc:h2:file:./data/auth-gateway;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE
DATABASE_USERNAME=sa
DATABASE_PASSWORD=
JPA_DDL_AUTO=update
H2_CONSOLE_ENABLED=false

ADMIN_ENABLED=false
ADMIN_DOCKER_ENABLED=true
ADMIN_SYSTEMD_ENABLED=true
ADMIN_PORTS_ENABLED=true

ALLOWED_EMAILS=
ALLOWED_DOMAINS=
REQUIRE_VERIFIED_EMAIL=true

AUTH_GATEWAY_JWT_PRIVATE_KEY_PATH=
AUTH_GATEWAY_JWT_PRIVATE_KEY=
AUTH_GATEWAY_JWT_KEY_ID=

JOB_CRM_URL=http://localhost:3000/job/
JOB_CRM_CLIENT_SECRET=replace-with-dev-or-deployment-secret
JOB_CRM_REDIRECT_URI=http://localhost:3000/login/oauth2/code/auth-gateway
JOB_CRM_LOGOUT_REDIRECT_URI=http://localhost:3000/job/

INTERVIEW_URL=http://localhost:3000/
INTERVIEW_CLIENT_SECRET=replace-with-dev-or-deployment-secret
INTERVIEW_REDIRECT_URI=http://localhost:3000/login/oauth2/code/auth-gateway
INTERVIEW_LOGOUT_REDIRECT_URI=http://localhost:3000/
